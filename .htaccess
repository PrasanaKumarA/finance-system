DirectoryIndex index.php

RewriteEngine On

# Redirect to index.php if no specific file is requested
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^$ index.php [L]

# Prevent directory listing
Options -Indexes

# Force correct MIME types and prevent InfinityFree text/html injections on PWA files
<IfModule mod_mime.c>
    AddType application/json .json
    AddType application/javascript .js
</IfModule>

<IfModule mod_rewrite.c>
    RewriteRule ^manifest\.json$ - [T=application/json]
    RewriteRule ^service-worker\.js$ - [T=application/javascript]
</IfModule>
